NODE_ENV=development
PORT=4000

# Single-line JSON string (no newlines). Required — service account files are not loaded.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your-project-id
# Firebase / GCS bucket for campaign assets (defaults to {project_id}.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=powerupgameon.firebasestorage.app

# CORS — comma-separated origins (Next.js app)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: single frontend URL merged into ALLOWED_ORIGINS (set on API Vercel project)
FRONTEND_URL=https://powerupgameon.vercel.app
# Optional: allow https://{project}.vercel.app and preview deployments
CORS_VERCEL_PROJECT=powerupgameon

# Secrets (use a secret manager in production)
API_CSRF_SECRET=change-me-long-random
SPIN_TOKEN_SECRET=change-me-different-long-random
SPIN_TOKEN_TTL_MINUTES=60

# Behind nginx / load balancer — enables accurate client IP for rate limits
TRUST_PROXY=1

# Optional: shared Redis for rate limit counters across API instances
REDIS_URL=

# Set to false/0 to disable all rate limiters (local stress testing only)
RATE_LIMIT_ENABLED=true

# Optional overrides (defaults shown)
# GLOBAL_RATE_LIMIT_MAX=200
# GLOBAL_RATE_LIMIT_WINDOW_SECS=900
# REGISTRATION_RATE_LIMIT_MAX=3
# SPIN_RATE_LIMIT_MAX=8
# RATE_LIMIT_KEY_PREFIX=staging

# Bootstrap API admin (Bearer tokens). Prefer: cargo run --bin set-auth-admin-claim -- <uid> --grant
ALLOWED_ADMIN_EMAILS=admin@steamenergy.com

# Optional: cross-check GPS against IP geolocation on registration (recommended in production)
IP_GEO_ENABLED=false
IP_GEO_MAX_DISTANCE_KM=150
# IP_GEO_API_URL=http://ip-api.com/json/{ip}?fields=status,lat,lon

# Vercel: set NODE_ENV=production in the project Environment Variables UI.
# Vercel: use redis://host:port (include scheme) for REDIS_URL.
# Vercel: add your frontend URL(s) to ALLOWED_ORIGINS, e.g. https://powerupgameon.vercel.app
