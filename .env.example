NODE_ENV=development
PORT=4000

# Single-line JSON string (no newlines). Required — service account files are not loaded.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your-project-id

# CORS — comma-separated origins (Next.js app)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Secrets (use a secret manager in production)
API_CSRF_SECRET=change-me-long-random
SPIN_TOKEN_SECRET=change-me-different-long-random

# Behind nginx / load balancer — enables accurate client IP for rate limits
TRUST_PROXY=1

# Optional: shared Redis for rate limit counters across API instances
REDIS_URL=

# Cap per real prize name (inventory)
REAL_PRIZE_LIMIT=5
